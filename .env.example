# 大模型 API Key（阿里云 DashScope，必填）
# 获取地址：https://help.aliyun.com/zh/model-studio/getting-started/first-api-call-to-qwen
DASHSCOPE_API_KEY="sk-your-api-key"

# Tavily 搜索 API Key（可选，DDG 搜索的备用方案）
# 获取地址：https://app.tavily.com/
TAVILY_API_KEY="tvly-your-api-key"

# 默认使用的模型（可选，推荐 qwen3.6-flash，速度快且免费额度充足）
LLM_MODEL="qwen3.6-flash"

# 阿里云 DashScope Embedding 模型（可选，text-embedding-v2=1536维, v3=1024维）
EMBEDDING_MODEL="text-embedding-v2"

# 阿里云 DashScope Rerank 模型（可选）
RERANK_MODEL="qwen3-vl-rerank"

# LlamaParse OCR 解析（可选，不配则仅用 pdfplumber 解析文本型 PDF）
# 获取地址：https://cloud.llamaindex.ai/
LLAMA_CLOUD_API_KEY="llx-your-api-key"

# 上传文件存储目录（可选，默认为项目根目录下的 uploads/）
UPLOAD_DIR="uploads"
